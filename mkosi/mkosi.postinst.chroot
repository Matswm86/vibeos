#!/bin/bash
# Runs INSIDE the built rootfs after all packages are installed, before
# the image is sealed. Analogous to v1's `chroot-inject.sh` but minimal —
# only things that genuinely can't be expressed as a .deb postinst end
# up here.

set -euo pipefail

echo "[mkosi.postinst] starting vibeos-specific postinst"

# ─── Display manager: SDDM is our greeter ────────────────────────────
# Ubuntu 24.04 may install gdm3 alongside SDDM depending on metapackage
# resolution. Force SDDM as the active display manager.
if [ -f /usr/bin/sddm ]; then
    echo "/usr/bin/sddm" > /etc/X11/default-display-manager
    systemctl disable gdm3 2>/dev/null || true
    systemctl disable lightdm 2>/dev/null || true
    systemctl enable sddm
fi

# ─── Default shell: zsh (we promised this in v2-plan.md) ─────────────
# Ubuntu's useradd defaults still point at /bin/bash; flip the
# system-wide default so both the live user and any post-install
# accounts get zsh unless they override.
if [ -x /usr/bin/zsh ]; then
    sed -i 's|^SHELL=.*|SHELL=/usr/bin/zsh|' /etc/default/useradd || true
    sed -i 's|^DSHELL=.*|DSHELL=/usr/bin/zsh|' /etc/adduser.conf || true
fi

# ─── Flatpak + Flathub ──────────────────────────────────────────────
if command -v flatpak >/dev/null 2>&1; then
    flatpak remote-add --if-not-exists --system flathub \
        https://flathub.org/repo/flathub.flatpakrepo || true
fi

# ─── Live user for the ISO boot (before install) ────────────────────
# Calamares will create the real user during install. This one exists
# only during the live session so someone can click "Install" without
# a root shell. Password is "vibeos" (live-only, documented, not secret).
if ! id vibeos >/dev/null 2>&1; then
    # Build supplementary group list from only those that actually exist in
    # the chroot — NetworkManager's `netdev` group is created by its postinst
    # which needs dbus, and dbus isn't running in the chroot. Same caveat for
    # `plugdev`. Missing groups get added at first boot by systemd-sysusers.
    GROUPS=""
    for g in sudo audio video plugdev netdev; do
        getent group "$g" >/dev/null 2>&1 && GROUPS="${GROUPS:+$GROUPS,}$g"
    done
    useradd -m -s /usr/bin/zsh -G "$GROUPS" vibeos
    echo 'vibeos:vibeos' | chpasswd
    # Auto-login in the live session only — SDDM config
    mkdir -p /etc/sddm.conf.d
    cat > /etc/sddm.conf.d/autologin.conf <<EOF
[Autologin]
User=vibeos
Session=plasma
Relogin=false
EOF
fi

# ─── Live-session autostart: Calamares + Vibbey install-helper ────────
# On the live ISO, we autostart Calamares + Vibbey's install-helper
# sidebar the moment Plasma loads. The wrapper script checks for the
# /etc/vibeos/live-session marker (present only on the live ISO; removed
# from the target by Calamares' contextualprocess during install) so
# nothing autostarts on the real installed system.
if [ -f /usr/bin/calamares ]; then
    # 1. Wrapper script that gates on the live-session marker
    install -d -m 0755 /usr/libexec/vibeos
    cat > /usr/libexec/vibeos/live-autostart <<'LIVE_EOF'
#!/bin/sh
# Runs at Plasma session start. Only acts in the live ISO session.
[ -f /etc/vibeos/live-session ] || exit 0
# Launch Vibbey install-helper first (right-pinned sidebar) so the
# guidance appears alongside Calamares, not behind it.
/usr/bin/vibbey --install-helper >/tmp/vibbey-install-helper.log 2>&1 &
# Give Vibbey 300 ms to claim the right edge before Calamares opens
sleep 0.3
# Calamares needs root via pkexec on Ubuntu Noble
exec pkexec /usr/bin/calamares
LIVE_EOF
    chmod 0755 /usr/libexec/vibeos/live-autostart

    # 2. Autostart .desktop entry (system-wide — applies to every user
    # including the live `vibeos` autologin account)
    install -d -m 0755 /etc/xdg/autostart
    cat > /etc/xdg/autostart/vibeos-live-installer.desktop <<'AUTOSTART_EOF'
[Desktop Entry]
Type=Application
Name=VibeOS Live Installer
Comment=Launches Calamares + Vibbey guidance on first login to the live session
Exec=/usr/libexec/vibeos/live-autostart
Icon=/usr/share/calamares/branding/vibeos/vibeos-icon.svg
Terminal=false
X-GNOME-Autostart-enabled=true
# Skip if the live marker was stripped by Calamares (installed system)
TryExec=/usr/libexec/vibeos/live-autostart
AUTOSTART_EOF

    # 3. Keep a clickable desktop shortcut as a belt-and-braces fallback,
    # in case the user closes Calamares without installing and wants
    # to re-open it. Still branded; uses the same pkexec wrapper.
    mkdir -p /home/vibeos/Desktop
    cat > /home/vibeos/Desktop/install-vibeos.desktop <<'SHORTCUT_EOF'
[Desktop Entry]
Type=Application
Name=Install VibeOS
Comment=Install Pacific Dawn to this computer
Exec=pkexec calamares
Icon=/usr/share/calamares/branding/vibeos/vibeos-icon.svg
Terminal=false
Categories=System;
SHORTCUT_EOF
    chmod +x /home/vibeos/Desktop/install-vibeos.desktop
    chown -R vibeos:vibeos /home/vibeos/Desktop
fi

# ─── Vibbey first-run autostart must SKIP live session ────────────────
# vibeos-vibbey.deb ships /etc/xdg/autostart/vibbey-first-run.desktop
# which ran Vibbey chat in BOTH live session AND installed system.
# Rewrite Exec= so it short-circuits when /etc/vibeos/live-session exists.
VFR=/etc/xdg/autostart/vibbey-first-run.desktop
if [ -f "$VFR" ]; then
    sed -i 's|^Exec=.*|Exec=/bin/sh -c "test ! -f /etc/vibeos/live-session \&\& test ! -f $HOME/.vibeos/first-run-complete \&\& /usr/bin/vibbey"|' "$VFR"
fi

# ─── Plymouth default theme ──────────────────────────────────────────
# update-alternatives can fail in chroot, so write plymouthd.conf
# directly — the daemon reads Theme= from there at boot, which trumps
# the /etc/alternatives symlink. Belt-and-braces: also try the usual
# helpers so future upgrades don't clobber our choice.
install -d -m 0755 /etc/plymouth
cat > /etc/plymouth/plymouthd.conf <<'PLYEOF'
[Daemon]
Theme=vibeos-pacific-dawn
ShowDelay=0
DeviceTimeout=8
PLYEOF

if command -v plymouth-set-default-theme >/dev/null 2>&1; then
    plymouth-set-default-theme vibeos-pacific-dawn || true
fi

# Register our theme with the alternatives system so Ubuntu's own
# triggers don't overwrite the choice on next apt update.
if command -v update-alternatives >/dev/null 2>&1; then
    update-alternatives --install \
        /usr/share/plymouth/themes/default.plymouth default.plymouth \
        /usr/share/plymouth/themes/vibeos-pacific-dawn/vibeos-pacific-dawn.plymouth \
        200 2>/dev/null || true
    update-alternatives --set default.plymouth \
        /usr/share/plymouth/themes/vibeos-pacific-dawn/vibeos-pacific-dawn.plymouth \
        2>/dev/null || true
fi

# update-initramfs in chroot usually fails (no running kernel), but
# try anyway — mkosi regenerates the initrd from the rootfs later and
# picks up /etc/plymouth/plymouthd.conf at that stage.
update-initramfs -u -k all 2>/dev/null || true

# ─── os-release ─ keep vibeos-desktop.deb's version authoritative ────
if [ -f /usr/lib/vibeos/os-release ]; then
    install -m 0644 /usr/lib/vibeos/os-release /etc/os-release
fi

# ─── Baked-extras ownership + HARD assertions ───────────────────────
# scripts/bake-extras.sh pre-populates:
#   /usr/share/ollama/.ollama/models/  — qwen2.5:3b (1.9 GB)
#   /usr/lib/node_modules/@anthropic-ai/claude-code/ + /usr/bin/claude (64 MB)
#   /etc/vibeos/live-session (marker, removed by Calamares during install)
# The chroot has no network, so all three MUST already be in place here.
# Anything missing is a build-kill bug — do NOT ship a "quietly broken" ISO.

echo "[mkosi.postinst] verifying baked extras"

# Ollama model
if ! id ollama >/dev/null 2>&1; then
    echo "[mkosi.postinst] FATAL: ollama user missing (vibeos-vibbey.deb/ollama.deb didn't run postinst)" >&2
    exit 1
fi
if [ ! -f /usr/share/ollama/.ollama/models/manifests/registry.ollama.ai/library/qwen2.5/3b ]; then
    echo "[mkosi.postinst] FATAL: qwen2.5:3b manifest missing — run scripts/bake-extras.sh before build" >&2
    exit 1
fi
# Fix ownership (tar copy from mkosi.extra lands as root)
chown -R ollama:ollama /usr/share/ollama
echo "[mkosi.postinst] ollama model qwen2.5:3b verified + chowned"

# Claude Code CLI
if [ ! -x /usr/bin/claude ] || [ ! -d /usr/lib/node_modules/@anthropic-ai/claude-code ]; then
    echo "[mkosi.postinst] FATAL: Claude Code not baked — run scripts/bake-extras.sh before build" >&2
    exit 1
fi
if [ -f /usr/share/vibeos/CLAUDE_BAKED_VERSION ]; then
    CLAUDE_VER=$(cat /usr/share/vibeos/CLAUDE_BAKED_VERSION)
    echo "[mkosi.postinst] claude verified: $CLAUDE_VER"
fi

# Live-session marker (must be present on live ISO; Calamares strips it)
if [ ! -f /etc/vibeos/live-session ]; then
    echo "[mkosi.postinst] FATAL: /etc/vibeos/live-session missing — bake-extras.sh drops this" >&2
    exit 1
fi
echo "[mkosi.postinst] live-session marker present"

# ─── Clean up apt cache to shave ~300MB off the ISO ─────────────────
apt-get clean
rm -rf /var/lib/apt/lists/*
# Clean npm cache to trim another ~80MB that isn't needed at runtime
if command -v npm >/dev/null 2>&1; then
    npm cache clean --force 2>/dev/null || true
    rm -rf /root/.npm 2>/dev/null || true
fi

echo "[mkosi.postinst] done"
