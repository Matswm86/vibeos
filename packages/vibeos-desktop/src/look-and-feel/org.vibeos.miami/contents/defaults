[kdeglobals][KDE]
LookAndFeelPackage=org.vibeos.miami

[kdeglobals][General]
ColorScheme=VibeOS-Miami
Name=VibeOS-Miami

[kdeglobals][Icons]
Theme=Papirus

[plasmarc][Theme]
name=default

[kcminputrc][Mouse]
cursorTheme=breeze_cursors

[kwinrc][org.kde.kdecoration2]
library=org.kde.breeze
theme=Breeze
NoPlugin=false
ButtonsOnLeft=M
ButtonsOnRight=IAX

[kwinrc][WindowSwitcher]
LayoutName=thumbnails

[kwinrc][DesktopSwitcher]
LayoutName=org.kde.breeze.desktop

[kscreenlockerrc][Greeter][Wallpaper][org.kde.image][General]
Image=/usr/share/wallpapers/VibeOS-Miami/contents/images/3840x2160.png

[plasma-org.kde.plasma.desktop-appletsrc][Containments][1][Wallpaper][org.kde.image][General]
Image=/usr/share/wallpapers/VibeOS-Miami/

[ksmserverrc][General]
loginMode=emptySession
