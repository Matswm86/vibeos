{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Permissive defaults for a VibeOS dev workstation. Claude Code may read, write, and run commands in ~/workspace. Adjust permissions if you work with sensitive data here.",
  "permissions": {
    "allow": [
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(npm:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(node:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(uv:*)",
      "Bash(pytest:*)",
      "Bash(cargo:*)",
      "Bash(rustc:*)",
      "Bash(make:*)",
      "Bash(docker:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(ripgrep:*)",
      "Bash(rg:*)",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf /*)",
      "Bash(dd:*)",
      "Bash(mkfs.*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)"
    ]
  },
  "env": {
    "EDITOR": "kate"
  }
}
