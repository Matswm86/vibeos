.env
.env.*
*.log
__pycache__/
*.pyc
.DS_Store
node_modules/

# Build artifacts
mkosi.output/
mkosi.cache/
*.iso
*.iso.sha256
*.raw
build/
dist/

# Debian build byproducts
packages/*/debian/.debhelper/
packages/*/debian/debhelper-build-stamp
packages/*/debian/files
packages/*/debian/*.substvars
packages/*/debian/*.debhelper.log
packages/*/*.deb
packages/*/*.buildinfo
packages/*/*.changes
packages/local/
packages/*/debian/vibeos-desktop/
packages/*/debian/.debhelper/
packages/*/debian/tmp/

# Rendered wallpapers (rsvg-convert output from SVG sources at .deb build time)
packages/vibeos-desktop/src/wallpapers/VibeOS-Miami/contents/images/*.png
packages/vibeos-desktop/src/wallpapers/VibeOS-NeonGrid/contents/images/*.png
packages/vibeos-desktop/src/wallpapers/VibeOS-Outrun/contents/images/*.png

# apt-repo state (pool/dists populated by reprepro, not checked in)
apt-repo/db/
apt-repo/pool/
apt-repo/dists/

# mkosi secrets
mkosi/mkosi.rootpw
mkosi/mkosi.key
mkosi/mkosi.crt
